# Database
DATABASE_URL=postgres://ras:ras_secret@localhost:5432/readandsign

# Security
JWT_SECRET=change_me_in_production_jwt_secret_32chars
SIGNING_SECRET=change_me_signing_secret

# Server
PORT=3000
NODE_ENV=development
UPLOAD_DIR=/uploads

# App URL (used in emails)
APP_URL=http://localhost

# Email / SMTP (optional - emails log to console if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@readandsign.app
SMTP_SECURE=false

# Database seeding
SEED=true
